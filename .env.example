# Composio App Research Agent — Environment Variables
# Copy this file to .env and fill in your API keys

# Primary LLM backend: Groq. The pipeline uses Groq's OpenAI-compatible API.
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_...
GROQ_MODEL=openai/gpt-oss-120b

# Optional fallback: OpenRouter
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=<your-json-capable-model>

# Optional: Composio SDK API key (get from composio.dev). On Python 3.14 the
# SDK dependency is currently skipped because of an incompatible Pillow pin.
COMPOSIO_API_KEY=...

# Optional: Firecrawl API key (fallback scraping, get from firecrawl.dev)
FIRECRAWL_API_KEY=fc-...

# Optional: GitHub Personal Access Token (for MCP existence checks)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...

# Pipeline Configuration (optional overrides)
# RESEARCH_CONCURRENCY=5
# RETRY_ATTEMPTS=3
# REQUEST_TIMEOUT=30
# SCRAPE_MAX_TOKENS=4000
# VERIFICATION_SAMPLE_SIZE=25
